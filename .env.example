# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL: The model used by the AI chat endpoint.
OPENROUTER_MODEL="google/gemma-4-31b-it:free"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Optional: owner-only email alerts when a user joins ---
OWNER_USERNAME="MoHamed"
EMAIL_NOTIFICATIONS_ENABLED="false"
OWNER_EMAIL_TO="owner@example.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp_user@example.com"
SMTP_PASS="smtp_password"
SMTP_FROM="Gemini Alerts <no-reply@example.com>"
